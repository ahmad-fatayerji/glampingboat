// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  // output   = "../generated/prisma" Keep commented 
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(dbgenerated("concat('usr_', replace(cast(gen_random_uuid() as text), '-', ''))")) @db.Text
  email     String   @unique
  name      String?
  avatar    String?
  password  String?
  resetToken           String?  // <-- new
  resetTokenExpiresAt  DateTime?// <-- new
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reservations  Reservation[]
}

model Reservation {
  id        String   @id @default(uuid())           // simple, Postgres‑native UUID
  userId    String   @db.Text                       // foreign key
  user      User     @relation(fields: [userId], references: [id])
  date      DateTime                                // the day of the reservation
  timeSlot  String                                  // e.g. "09:00", "11:00"
  createdAt DateTime @default(now())

  @@unique([date, timeSlot], name: "unique_reservation_slot")
}